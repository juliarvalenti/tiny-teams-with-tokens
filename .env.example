# Anthropic — required to run real agent calls (milestone 4+)
ANTHROPIC_API_KEY=

# Source connectors — required only for milestones 5-7
GITHUB_TOKEN=
CONFLUENCE_BASE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=
# Webex personal access token (~12h lifetime). Required only for milestone 7.
# NEVER commit this. NEVER paste into chat.
WEBEX_TOKEN=

# Paths (defaults are fine for local dev)
TTT_DB_PATH=./data/ttt.db
TTT_REPORT_REPO=./data/reports.git
TTT_REPORT_WORKTREE=./data/reports-wc
